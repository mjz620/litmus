# Public Supabase project values. The anon key is safe for the browser; RLS is not optional.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Never prefix this value with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-only OpenAI orchestration. Leave unset to use deterministic mock mode.
OPENAI_API_KEY=
OPENAI_COACH_MODEL=gpt-5.4-mini
OPENAI_EVALUATOR_MODEL=gpt-5.4-mini
OPENAI_MOCK_MODE=1

# Adobe Fonts Web Project stylesheet. Create one project containing Tomarik
# Display (regular) and Neulis Sans (regular, medium, semibold, bold), then
# paste the generated URL here. Example: https://use.typekit.net/xxxxxxx.css
# Do not download or commit Adobe font files.
NEXT_PUBLIC_ADOBE_FONTS_STYLESHEET=<ADOBE_FONTS_WEB_PROJECT_STYLESHEET>
