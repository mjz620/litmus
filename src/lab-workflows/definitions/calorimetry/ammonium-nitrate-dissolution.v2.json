  "instructions": [
    {
      "id": "instruction.weigh",
      "title": "Tare, weigh, and record the solid",
      "guidance": "Place the empty weighing boat on the balance, tare it, transfer 2.50 g of ammonium nitrate, and record the displayed mass.",
      "relatedRuleIds": [
        "rule.boat_placed",
        "rule.balance_tared",
        "rule.solid_weighed",
        "rule.mass_read",
        "rule.tare_before_weigh"
      ]
    },
    {
      "id": "instruction.dissolve",
      "title": "Dissolve the measured sample",
      "guidance": "Add 100.00 mL of 20.0 °C water to the calorimeter, remove the boat from the balance, transfer the weighed solid into the water, and mix.",
      "relatedRuleIds": [
        "rule.water_added",
        "rule.solid_added",
        "rule.mixed",
        "rule.weigh_before_add"
      ]
    },
    {
      "id": "instruction.measure",
      "title": "Measure the temperature and enthalpy",
      "guidance": "Place the thermometer, record the final temperature, and compare the measured molar enthalpy with the 25 °C literature value of +25.7 kJ/mol.",
      "relatedRuleIds": [
        "rule.temperature_read",
        "rule.temperature_drop",
        "rule.enthalpy_result",
        "rule.complete"
      ]
    }
