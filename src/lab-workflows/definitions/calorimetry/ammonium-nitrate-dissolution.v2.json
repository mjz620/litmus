  "revision": 1,
  "sourceRequest": "Create a mass-measured ammonium nitrate dissolution calorimetry lab following Purdue Chemistry demonstration sheet 21.3 and the University of York Chemistry Teaching Labs tared-weighing procedure, adapted to a 2.50 g student sample and an insulated coffee-cup calorimeter.",
  "metadata": {
    "title": "Measure the enthalpy of ammonium nitrate dissolution",
    "learningObjective": "Use a tared balance and coffee-cup calorimeter to connect measured solid mass, temperature change, and molar enthalpy.",
    "studentSummary": "Tare a weighing boat, weigh 2.50 g of ammonium nitrate, add it to 100.00 mL of water, mix, and record the cooling caused by endothermic dissolution.",
    "gradeBand": "mixed_high_school",
    "estimatedMinutes": 15,
    "difficulty": "intermediate",
    "tags": [
      "calorimetry",
      "dissolution",
      "mass measurement",
      "Purdue Chemistry demonstration 21.3",
      "University of York Chemistry Teaching Labs weighing solids"
    ],
    "accessibilityNotes": [
      "Balance and thermometer readings are exposed as text with units.",
      "Every weighing, transfer, mixing, and reading action has a keyboard control."
    ],
    "deviceProfileId": "device.chromebook_core.v1"
  },
  "objectiveIds": ["measure_mass", "measure_dissolution_enthalpy"],
