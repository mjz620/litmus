  "instructions": [
    {
      "id": "read_initial_burette",
      "title": "Read the burette",
      "guidance": "At eye level, record the bottom of the concave meniscus.",
      "relatedRuleIds": ["migration.rule.s1.o1", "migration.rule.s1.completion"]
    },
    {
      "id": "approach_endpoint",
      "title": "Approach the endpoint",
      "guidance": "Add titrant slowly, switching to dropwise control near the endpoint.",
      "relatedRuleIds": ["migration.rule.s2.o1", "migration.rule.s2.completion"]
    }
  ],
