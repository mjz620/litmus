  "instructions": [
    {
      "id": "instruction.inspect_solutions",
      "title": "Identify the ions in each bottle",
      "guidance": "Read both labels and write down the cation and anion each solution contributes before you combine anything.",
      "relatedRuleIds": ["rule.silver_poured"]
    },
    {
      "id": "instruction.combine",
      "title": "Combine the solutions in the beaker",
      "guidance": "Pour a measured volume of each solution into the same beaker. Watch the moment the second solution meets the first.",
      "relatedRuleIds": ["rule.silver_poured", "rule.chloride_poured"]
    },
    {
      "id": "instruction.identify_product",
      "title": "Identify the precipitate",
      "guidance": "Compare the reported ion product Q with Ksp. Note whether a solid appeared and what colour it is, then identify the reacting and spectator ions.",
      "relatedRuleIds": ["rule.chloride_poured"]
    },
    {
      "id": "instruction.weigh_product",
      "title": "Collect and weigh the dry product",
      "guidance": "Place the empty boat on the balance, tare it, remove it, then collect the filtered, washed, and fully dried precipitate. Return the boat to the balance and record the displayed dry mass.",
      "relatedRuleIds": [
        "rule.balance_tared",
        "rule.precipitate_collected",
        "rule.mass_read",
        "rule.workflow_complete"
      ]
    }
